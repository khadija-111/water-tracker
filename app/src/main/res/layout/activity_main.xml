<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFB">

    <!-- AppBar avec Gradient Inline -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="8dp"
        android:background="@android:color/transparent"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E88E5"
            android:paddingTop="8dp">

            <!-- Header avec logo et titre -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="20dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💧"
                    android:textSize="32sp"
                    android:layout_marginEnd="8dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Water Time"
                        android:textSize="26sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Restez hydraté, restez en forme"
                        android:textSize="11sp"
                        android:textColor="#B3E5FC"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Séparateur décoratif -->
            <View
                android:layout_width="60dp"
                android:layout_height="3dp"
                android:background="#4ECDC4"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"/>

            <!-- TabLayout Moderne -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                app:tabMode="fixed"
                app:tabGravity="fill"
                app:tabIndicatorColor="#4ECDC4"
                app:tabIndicatorHeight="4dp"
                app:tabIndicatorFullWidth="false"
                app:tabSelectedTextColor="#FFFFFF"
                app:tabTextColor="#80FFFFFF"
                app:tabIconTint="@android:color/white"
                app:tabRippleColor="#204ECDC4"
                app:tabTextAppearance="@style/CustomTabText"
                android:background="@android:color/transparent"
                android:elevation="0dp"/>

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ViewPager avec animation -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8FAFB"/>

</LinearLayout>